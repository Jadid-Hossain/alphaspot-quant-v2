{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["bun-types"],
    "paths": {
      "@/*": ["../../src/*"]
    },
    "baseUrl": "."
  },
  "include": ["*.ts", "../../src/lib/alphaspot/**/*.ts", "../../src/lib/db.ts"]
}
