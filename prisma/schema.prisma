// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// AlphaSpot trading AI models

model Trade {
  id            String   @id @default(cuid())
  symbol        String   // e.g. BTC/USDT
  side          String   // BUY | SELL
  kind          String   // INITIAL | RECOVERY | TAKE_PROFIT | EMERGENCY_EXIT
  price         Float
  quantity      Float
  quoteValue    Float    // price * quantity (USDT notional)
  avgEntryPrice Float?   // weighted average entry after this trade
  positionQty   Float?   // total position quantity after this trade
  state         String   // FLAT | IN_TRADE | RECOVERY_MODE
  realizedPnl   Float?   // realized profit/loss in USDT (only on SELL)
  score         Int      // confluence score at the time of trade
  reason        String   // human/LLM-readable reason
  createdAt     DateTime @default(now())

  @@index([symbol, createdAt])
  @@index([createdAt])
}

model Signal {
  id            String   @id @default(cuid())
  symbol        String
  score         Int      // -100 to +100
  label         String   // STRONG_BUY | BUY | HOLD | SELL | STRONG_SELL | RECOVERY_BUY | TAKE_PROFIT
  state         String   // FLAT | IN_TRADE | RECOVERY_MODE
  price         Float
  indicatorsJson String  // JSON blob of all indicator values
  patternsJson  String   // JSON blob of detected patterns
  sentiment     Float?   // -1 to 1
  fearGreed     Int?     // 0 to 100
  createdAt     DateTime @default(now())

  @@index([symbol, createdAt])
  @@index([createdAt])
}

model ReasoningLog {
  id        String   @id @default(cuid())
  symbol    String
  source    String   // ENGINE | LLM | SYSTEM
  level     String   // INFO | WARN | SIGNAL | TRADE | ERROR
  message   String
  createdAt DateTime @default(now())

  @@index([symbol, createdAt])
  @@index([createdAt])
}

model EngineConfig {
  id                String  @id @default("singleton")
  allocatedCapital  Float   @default(10000) // total USDT allocated to this engine
  initialPct        Float   @default(0.20)  // 20% for initial entry
  recoveryPct       Float   @default(0.30)  // 30% for recovery buy
  dropThresholdPct  Float   @default(2.0)   // % drop to trigger recovery
  takeProfitPct     Float   @default(1.0)   // % profit to take profit (1%)
  strongBuyScore    Int     @default(75)
  strongSellScore   Int     @default(-75)
  enabled           Boolean @default(true)
}

// Ethical Structural Constraints — Shariah Compliance Mode
// Tracks whether an asset passes Shariah screening (utility test, no
// interest-based lending, no gambling, no prohibited speculation).
model AssetCompliance {
  id                  String   @id @default(cuid())
  symbol              String   @unique // canonical "BTC/USDT"
  base                String   // "BTC"
  isShariahCompliant  Boolean  @default(false)
  complianceReason    String   @default("Pending compliance review")
  complianceCategory  String   @default("PENDING") // COMPLIANT | HARAM | PENDING
  classifiedAt        DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([isShariahCompliant])
  @@index([base])
}

// Chapter 3.4 — Historical Data Manager (metadata store)
// Stores dataset metadata; actual OHLCV payloads live in the columnar
// Payload Store (§15 — physically separated from transactional DB).
model HistoricalDataset {
  id                        String   @id @default(cuid())
  datasetId                 String   @unique // canonical dataset identifier
  version                   Int      // monotonically increasing version
  exchange                  String   // e.g. "binance"
  symbol                    String   // canonical "BTC/USDT"
  timeframe                 String   // e.g. "15m"
  startTime                 Int      // UTC Unix epoch (seconds) §9.1
  endTime                   Int      // UTC Unix epoch (seconds)
  candleCount               Int
  importTimestamp           BigInt   // UTC Unix epoch (ms)
  source                    String   // "exchange-rest" | "exchange-archive" | "internal-replay"
  validationStatus          String   @default("PENDING") // PENDING | VALIDATED | QUARANTINED | FAILED
  normalizationVersion      String   @default("1.0.0")
  featureCompatibilityVersion String  @default("2.0.0") // §18.1
  storageLocation           String   // path/key in the payload store
  storageFormat             String   @default("columnar") // columnar | parquet | arrow | duckdb
  coveragePct               Float    @default(0) // §10 data quality
  missingCandleCount        Int      @default(0)
  repairCount               Int      @default(0)
  importErrorCount          Int      @default(0)
  healthScore               Float    @default(0) // 0..1
  retentionStatus           String   @default("ACTIVE") // ACTIVE | ARCHIVED | COMPRESSED | RETIRED
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([symbol, timeframe, version])
  @@index([exchange, symbol])
  @@index([validationStatus])
  @@index([retentionStatus])
}
